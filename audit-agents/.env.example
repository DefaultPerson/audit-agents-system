# ============================================
# Smart Contract Audit System Configuration
# ============================================

# RPC Endpoints
ETH_RPC_URL=https://lb.drpc.org/ogrpc?network=ethereum&dkey=YOUR_DRPC_KEY
BSC_RPC_URL=https://lb.drpc.org/ogrpc?network=bsc&dkey=YOUR_DRPC_KEY
BASE_RPC_URL=https://mainnet.base.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Local node RPC (for Rust extractor - requires debug API)
# ERIGON_RPC_URL=http://localhost:8545

# HTTP Proxies for Dedaub API (optional, comma-separated)
# Format: http://user:pass@ip:port or http://ip:port
# HTTP_PROXIES=http://user1:pass1@1.2.3.4:8080,http://5.6.7.8:3128

# Block Explorer API Keys
ETHERSCAN_API_KEY=your_etherscan_api_key
BSCSCAN_API_KEY=your_bscscan_api_key
BASESCAN_API_KEY=your_basescan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
ARBISCAN_API_KEY=your_arbiscan_api_key

# Voyage AI (for RAG embeddings)
# Get key at: https://www.voyageai.com/
VOYAGE_API_KEY=your_voyage_api_key
VOYAGE_PAID=false  # Set to true for paid tier (larger batches)

# Dedaub Decompiler
# Get session cookies from browser after logging in to app.dedaub.com
# DEDAUB_COOKIES=__Host-next-auth.csrf-token=...;__Secure-next-auth.session-token.0=...
# DEDAUB_POLL_ATTEMPTS=120
# DEDAUB_POLL_INTERVAL_SECONDS=2

# OpenAI-compatible Autoresearch Model Handoff
AUTORESEARCH_OPENAI_BASE_URL=https://api.openai.com/v1
AUTORESEARCH_API_KEY=
AUTORESEARCH_RESEARCHER_MODEL=gpt-5.2
AUTORESEARCH_SKEPTIC_MODEL=gpt-5.2

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Claude Code OAuth Token (for headless daemon mode)
# Get with: jq -r '.claudeAiOauth.accessToken' ~/.claude/.credentials.json
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Direct Anthropic API (optional, for burst capacity)
# ANTHROPIC_API_KEY=sk-ant-api...
